<Window x:Class="Agent.TrayClient.PaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="620"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Marge = espace pour l'ombre portée -->
    <Border x:Name="Shell"
            Background="White"
            CornerRadius="12"
            Margin="20"
            Padding="0,0,0,10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="5"
                              Opacity="0.18"
                              Color="#000000"
                              Direction="270"/>
        </Border.Effect>

        <StackPanel>

            <!-- ── Zone de recherche ────────────────────────────────────── -->
            <Grid Margin="16,14,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TextBox + placeholder superposés -->
                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox"
                             FontSize="16"
                             Padding="2,5"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Panel.ZIndex="1"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"/>
                    <TextBlock Text="Rechercher... (CP12, demande, etc.)"
                               FontSize="15"
                               Padding="3,6"
                               Foreground="#888888"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Badge type détecté -->
                <Border x:Name="TypeBadge"
                        Grid.Column="1"
                        CornerRadius="4"
                        Padding="8,3"
                        Margin="10,0,0,0"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TypeLabel"
                               FontSize="11"
                               FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- Séparateur -->
            <Rectangle Height="1" Margin="0,10,0,0" Fill="#EBEBEB"/>

            <!-- Spinner de chargement (hauteur 2 px, invisible par défaut) -->
            <ProgressBar x:Name="Spinner"
                         IsIndeterminate="True"
                         Height="2"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#1565C0"
                         Visibility="Collapsed"/>

            <!-- ── Groupes de résultats ──────────────────────────────────── -->
            <ScrollViewer MaxHeight="440"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="GroupsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6,0,0">

                                <!-- En-tête coloré du système -->
                                <Border Background="{Binding HeaderBrush}" Padding="16,5">
                                    <TextBlock Text="{Binding SystemName}"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="11"/>
                                </Border>

                                <!-- Liste des résultats du groupe -->
                                <ItemsControl ItemsSource="{Binding Results}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,9"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="Result_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F0F4FF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               Foreground="#1A1A1A"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               FontSize="11"
                                                               Foreground="#757575"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Message vide -->
            <TextBlock x:Name="EmptyLabel"
                       Text="Aucun résultat trouvé."
                       Foreground="#9E9E9E"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,20"
                       Visibility="Collapsed"/>

        </StackPanel>
    </Border>
</Window>
